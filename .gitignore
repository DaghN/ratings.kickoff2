# Local secrets — never commit
.env
.env.*
!.env.example
site/config/ko2unitydb_config.local.php
site/config/ko2unitydb_config_work.local.php
site/config/ko2amiga_config.local.php
site/public_html/amiga/_import/*.sql
site/config/ladder.ini
site/config/ladder-work.ini
site/config/work-targets.ini
site/public_html/ops/config/work-targets.ini
site/public_html/ops/config/dispatch-http.ini

# Local database dumps (large; may contain account data) — never commit full DB exports
/data/dumps/*
!/data/dumps/README.md

# Amiga Access snapshot + discovery exports (large; may contain personal data)
/data/amiga/source/*
!/data/amiga/source/.gitkeep
/data/amiga/exports/*
!/data/amiga/exports/.gitkeep

/KO2PC_DB/

# Stray *.sql elsewhere (HeidiSQL exports, ad-hoc dumps). Canonical DDL is allowlisted below.
*.sql
!site/public_html/ops/sql/migrations/**/*.sql
!site/public_html/ops/sql/generalstatstable.sql
!scripts/ladder/sql/**/*.sql
!scripts/amiga/sql/**/*.sql
!schema/**/*.sql

# Laragon Apache shim build artifacts
laragon/*.exe

# Python
__pycache__/
*.py[cod]

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# TLS debug key logs (openssl/curl SSLKEYLOGFILE) — sensitive; never commit
/bad
sslkey.log
keylog.txt

# Server / editor noise under mirrored site
site/public_html/.cache/
site/public_html/.usermin/
**/dwsync.xml
**/_notes/

data/amiga/tournament_videos/raw/

